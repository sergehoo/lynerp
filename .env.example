# =============================================================================
# LYNEERP — Exemple de configuration (.env.example)
# Copier ce fichier en `.env` et remplir avec les vraies valeurs.
# Ne JAMAIS versionner le fichier `.env` (déjà ignoré dans .gitignore).
# =============================================================================

# --- Django ------------------------------------------------------------------
DJANGO_ENV=dev                       # dev | prod | test
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string-of-at-least-50-chars
DJANGO_DEBUG=1                       # 1 en dev, 0 en prod
ALLOWED_HOSTS=127.0.0.1,localhost,*.lyneerp.com
CSRF_TRUSTED_ORIGINS=https://*.lyneerp.com,https://lyneerp.com
LANGUAGE_CODE=fr-fr
TIME_ZONE=Africa/Abidjan
LOG_LEVEL=INFO
LOG_FILE=                            # ex: /var/log/lyneerp/app.log

# --- Database ----------------------------------------------------------------
DB_ENGINE=postgres                   # postgres | sqlite
DB_NAME=lyneerp
DB_USER=postgres
DB_PASSWORD=changeme
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

# --- Redis / Cache / Celery --------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# --- Multi-tenant ------------------------------------------------------------
DEFAULT_TENANT=acme
TENANT_SUBDOMAIN_REGEX=^(?P<tenant>[a-z0-9-]+)\.(?:rh\.)?lyneerp\.com$
LICENSE_ENFORCEMENT=0

# --- Keycloak ----------------------------------------------------------------
# URL publique (HTTPS) — utilisée par le NAVIGATEUR pour se rediriger sur
# la page de login Keycloak. C'est aussi l'issuer signé dans les JWT.
KEYCLOAK_BASE_URL=https://sso.lyneerp.com
KEYCLOAK_REALM=lyneerp
KEYCLOAK_ISSUER=https://sso.lyneerp.com/realms/lyneerp
KEYCLOAK_AUDIENCE=rh-core
KEYCLOAK_CLIENT_ID=rh-core
KEYCLOAK_CLIENT_SECRET=               # vide si client public
KEYCLOAK_USE_REALM_PER_TENANT=0

# URL interne — utilisée par DJANGO côté serveur (échange code→token,
# fetch JWKS, refresh, etc.). En Docker, c'est le hostname du service
# Keycloak sur le réseau interne (compose / k8s).
# Laissez vide pour utiliser la même URL que KEYCLOAK_BASE_URL (dev local
# sans Docker).
KEYCLOAK_INTERNAL_URL=http://keycloak:8080

# JWKS : si vide, dérivé automatiquement de KEYCLOAK_INTERNAL_URL.
KEYCLOAK_JWKS_URL=

# Overrides ultra-fins par endpoint (si vous avez une topologie exotique).
# Laissez vide en règle générale — settings/base.py les calcule à partir
# de KEYCLOAK_INTERNAL_URL.
OIDC_OP_AUTHORIZATION_ENDPOINT=
OIDC_OP_TOKEN_ENDPOINT=
OIDC_OP_USER_ENDPOINT=
OIDC_OP_JWKS_ENDPOINT=
OIDC_OP_DISCOVERY_ENDPOINT=

# --- MinIO / S3 --------------------------------------------------------------
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=lyneerp
S3_PUBLIC_HOST=                       # ex: minio.lyneerp.com
S3_PUBLIC_SCHEME=https
S3_REGION=us-east-1

# --- Email -------------------------------------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=no-reply@lyneerp.com

# --- Sécurité prod -----------------------------------------------------------
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SESSION_COOKIE_AGE=28800              # 8 heures
SESSION_COOKIE_DOMAIN=.lyneerp.com
CSRF_COOKIE_DOMAIN=.lyneerp.com

# --- IA (Ollama) -------------------------------------------------------------
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120
OLLAMA_DEFAULT_TEMPERATURE=0.2
OLLAMA_DEFAULT_TOP_P=0.9
OLLAMA_DEFAULT_MAX_TOKENS=2048

# --- IA — Recherche web ------------------------------------------------------
# Provider de recherche par défaut : ddg | brave | searx
WEB_SEARCH_PROVIDER=ddg
# Brave Search API key (https://brave.com/search/api/) si provider=brave
BRAVE_API_KEY=
# URL SearxNG auto-hébergé si provider=searx (ex. https://searx.example.com)
SEARX_URL=
# User-Agent et timeouts
WEB_SEARCH_USER_AGENT=Mozilla/5.0 (LyneERP-AI/1.0)
WEB_SEARCH_TIMEOUT=12
WEB_FETCH_TIMEOUT=15
WEB_FETCH_MAX_BYTES=2097152
WEB_SEARCH_CACHE_TTL=1800
WEB_FETCH_CACHE_TTL=21600
# Allowlist / blocklist domaines (vide = aucune contrainte au-delà du SSRF)
WEB_ALLOWLIST=
WEB_BLOCKLIST=facebook.com,instagram.com,tiktok.com
