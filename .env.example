# =============================================================================
# LYNEERP — Exemple de configuration (.env.example)
# Copier ce fichier en `.env` et remplir avec les vraies valeurs.
# Ne JAMAIS versionner le fichier `.env` (déjà ignoré dans .gitignore).
# =============================================================================

# --- Django ------------------------------------------------------------------
DJANGO_ENV=dev                       # dev | prod | test
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string-of-at-least-50-chars
DJANGO_DEBUG=1                       # 1 en dev, 0 en prod
ALLOWED_HOSTS=127.0.0.1,localhost,*.lyneerp.com
CSRF_TRUSTED_ORIGINS=https://*.lyneerp.com,https://lyneerp.com
LANGUAGE_CODE=fr-fr
TIME_ZONE=Africa/Abidjan
LOG_LEVEL=INFO
LOG_FILE=                            # ex: /var/log/lyneerp/app.log

# --- Database ----------------------------------------------------------------
DB_ENGINE=postgres                   # postgres | sqlite
DB_NAME=lyneerp
DB_USER=postgres
DB_PASSWORD=changeme
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

# --- Redis / Cache / Celery --------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# --- Multi-tenant ------------------------------------------------------------
DEFAULT_TENANT=acme
TENANT_SUBDOMAIN_REGEX=^(?P<tenant>[a-z0-9-]+)\.(?:rh\.)?lyneerp\.com$
LICENSE_ENFORCEMENT=0

# --- Keycloak ----------------------------------------------------------------
KEYCLOAK_BASE_URL=https://sso.lyneerp.com
KEYCLOAK_REALM=lyneerp
KEYCLOAK_ISSUER=https://sso.lyneerp.com/realms/lyneerp
KEYCLOAK_AUDIENCE=rh-core
KEYCLOAK_CLIENT_ID=rh-core
KEYCLOAK_CLIENT_SECRET=               # vide si client public
KEYCLOAK_JWKS_URL=https://sso.lyneerp.com/realms/lyneerp/protocol/openid-connect/certs
KEYCLOAK_USE_REALM_PER_TENANT=0
# Endpoints internes (override si on passe par le réseau Docker)
OIDC_OP_TOKEN_ENDPOINT=
OIDC_OP_USER_ENDPOINT=

# --- MinIO / S3 --------------------------------------------------------------
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=lyneerp
S3_PUBLIC_HOST=                       # ex: minio.lyneerp.com
S3_PUBLIC_SCHEME=https
S3_REGION=us-east-1

# --- Email -------------------------------------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=no-reply@lyneerp.com

# --- Sécurité prod -----------------------------------------------------------
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SESSION_COOKIE_AGE=28800              # 8 heures
SESSION_COOKIE_DOMAIN=.lyneerp.com
CSRF_COOKIE_DOMAIN=.lyneerp.com
